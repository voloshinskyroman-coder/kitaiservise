# Путь к рабочей директории демона (сессии, outreach.db, .env). По умолчанию — рядом со скриптами.
OUTREACH_DIR=

# Supabase — тот же проект, что и в webapp/.env.example (сервисный ключ, не anon)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram-бот для уведомлений оператору (approve/edit/skip черновиков ответов)
OPERATOR_BOT_TOKEN=
OPERATOR_USER_ID=

# Telegram-бот для алертов владельцу (сбои демона, флуд-баны и т.п.)
ALERT_BOT_TOKEN=
ALERT_USER_ID=

# LLM для черновиков ответов на входящие сообщения (ai.py)
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini

# Ссылка на Mini App KitaiService, которую AI вставляет в черновик при явном интересе лида
MINI_APP_URL=https://t.me/ВАШ_БОТ/app

# Опционально: перефразирование шаблонов рассылки через Claude (manager_daemon.py generate_variation)
ANTHROPIC_API_KEY=

# Пароль двухфакторной аутентификации для переавторизации сессий (qr_reauth3.py)
TWO_FA_PASSWORD=
